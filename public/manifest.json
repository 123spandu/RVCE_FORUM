{
  "name": "RVCE Connect - A campus forum app",
  "short_name": "RVCE Connect",
  "description": "The official unified notice board for RV College of Engineering. Stay updated with department circulars, hackathons, placements, and club events.",
  "start_url": "/app.html",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "theme_color": "#0f7a4d",
  "background_color": "#f4f7f5",
  "lang": "en-IN",
  "dir": "ltr",
  "categories": [
    "education",
    "productivity",
    "social"
  ],
  "id": "campus-connect-rvce-2024",
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "prefer_related_applications": false,
  "related_applications": [],
  "screenshots": [
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "RVCE Connect app icon"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "wide",
      "label": "RVCE Connect app icon"
    }
  ],
  "icons": [
    {
      "src": "/icons/icon-72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/icon-256.png",
      "sizes": "256x256",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "View Feed",
      "short_name": "Feed",
      "description": "Open the latest campus announcements",
      "url": "/app.html?tab=feed",
      "icons": [
        {
          "src": "/icons/icon-96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Compose Post",
      "short_name": "Post",
      "description": "Create a new announcement (publishers only)",
      "url": "/app.html?tab=compose",
      "icons": [
        {
          "src": "/icons/icon-96.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Communities",
      "short_name": "Communities",
      "description": "Browse and subscribe to departments and clubs",
      "url": "/app.html?tab=subs",
      "icons": [
        {
          "src": "/icons/icon-96.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "media",
          "accept": ["image/*"]
        }
      ]
    }
  },
  "file_handlers": [
    {
      "action": "/app.html?tab=compose&share=1",
      "accept": {
        "image/*": [".png", ".jpg", ".jpeg", ".webp", ".gif"]
      },
      "icons": [
        {
          "src": "/icons/icon-96.png",
          "sizes": "96x96"
        }
      ],
      "launch_type": "single-client"
    }
  ],
  "display_override": [
    "window-controls-overlay",
    "standalone",
    "minimal-ui"
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "handle_links": "preferred",
  "scope_extensions": [],
  "protocol_handlers": [
    {
      "protocol": "web+rvce",
      "url": "/app.html?post=%s"
    }
  ],
  "user_preferences": {
    "color_scheme_dark": {
      "theme_color": "#0b1220",
      "background_color": "#0b1220"
    }
  }
}